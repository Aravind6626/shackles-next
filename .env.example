# =============================================================================
# Shackles Symposium — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local (or .env) for development.
# NEVER commit .env.local or any file containing real secrets.

# App URL (used in reset-password links, email templates, and PWA metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL      → used at RUNTIME by the Next.js app (can be a pooler URL)
# DIRECT_DATABASE_URL → used by "prisma migrate" / "prisma db push" (direct TCP)
#
# Local development (matches docker-compose: host port 5433):
DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_local?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_local?schema=public
#
# --- Production option A: PgBouncer (transaction mode) ---
# DATABASE_URL=postgresql://user:pass@host:6432/shackles_symposium?pgbouncer=true
# DIRECT_DATABASE_URL=postgresql://user:pass@host:5432/shackles_symposium
#
# --- Production option B: Supabase pooler ---
# DATABASE_URL=postgresql://postgres:[PASS]@db.[REF].supabase.co:6543/postgres?pgbouncer=true
# DIRECT_DATABASE_URL=postgresql://postgres:[PASS]@db.[REF].supabase.co:5432/postgres
#
# --- Production option C: Neon pooler ---
# DATABASE_URL=postgresql://[user]:[pass]@[endpoint]-pooler.neon.tech/shackles?sslmode=require
# DIRECT_DATABASE_URL=postgresql://[user]:[pass]@[endpoint].neon.tech/shackles?sslmode=require

# -----------------------------------------------------------------------------
# Authentication & Sessions
# -----------------------------------------------------------------------------
# Generate a strong random value — minimum 32 characters.
# Both variables must have the same value; AUTH_SECRET is read by next-auth v5,
# SESSION_SECRET by the app's own session helpers.
SESSION_SECRET=replace-with-strong-random-secret-32chars
AUTH_SECRET=replace-with-strong-random-secret-32chars

# -----------------------------------------------------------------------------
# Yearly Controls (see README — Yearly Edition Bootstrap)
# -----------------------------------------------------------------------------
ACTIVE_YEAR=2026
ACTIVE_THEME_KEY=default
ACTIVE_PUBLIC_DOMAIN=localhost:3000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable scanner bulk team registration workflow (true/false)
ENABLE_SCANNER_BULK_TEAM_FLOW=false

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------

# Storage provider: local | digitalocean
STORAGE_PROVIDER=local

# DigitalOcean Spaces (required when STORAGE_PROVIDER=digitalocean)
# DO_SPACES_REGION=sgp1
# DO_SPACES_BUCKET=your-bucket-name
# DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
# DO_SPACES_KEY=replace-with-spaces-key
# DO_SPACES_SECRET=replace-with-spaces-secret
# DO_SPACES_CDN_BASE_URL=https://your-bucket-name.sgp1.cdn.digitaloceanspaces.com

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# The app supports two email providers: "resend" (default) and "smtp".
# Set EMAIL_PROVIDER to choose which one to use.
#
# For local development without email, leave these blank — emails will
# silently fail (logged to console) and no error is thrown to the user.
# -----------------------------------------------------------------------------

# Provider selector: resend | smtp  (defaults to "resend")
# EMAIL_PROVIDER=resend

# Sender address / display name
# EMAIL_FROM=Shackles Symposium <noreply@yourdomain.com>

# --- Option A: Resend (https://resend.com — free tier: 3,000 emails/month) ---
# RESEND_API_KEY=re_replace-with-your-resend-api-key
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Option B: SMTP (Gmail, Mailgun, etc.) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Shackles Symposium" <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Valkey (BullMQ workers + distributed rate limiting)
# -----------------------------------------------------------------------------
# Valkey is a Redis-compatible fork by the Linux Foundation.
# Used by src/lib/valkey.ts for BullMQ background job workers (CSV exports, etc.)
# The connection uses the redis:// protocol (wire-compatible with Valkey).
# Defaults to redis://localhost:6379 if not set.
# VALKEY_URL=redis://localhost:6379

# Upstash Redis REST (optional — distributed rate limiting in production)
# Upstash is Valkey/Redis-compatible. Used by src/lib/rate-limit.ts when present.
# Without this, rate limiting falls back to in-memory (dev / single-node only).
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token

# -----------------------------------------------------------------------------
# AI Integration (optional — needed for chatbot / AI features)
# -----------------------------------------------------------------------------
# Uses the Google Gemini API via @google/genai SDK.
# Get your key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=replace-with-gemini-api-key

# -----------------------------------------------------------------------------
# Error Tracking & Monitoring (Sentry)
# -----------------------------------------------------------------------------
# Sign up at https://sentry.io — free tier allows 5K errors/month.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxx  # Only needed in CI for source map uploads
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=shackles-symposium

# -----------------------------------------------------------------------------
# Docker Compose / Production Database (used by docker-compose.yml)
# -----------------------------------------------------------------------------
# These are NOT read by the Next.js app directly; they parameterize
# the docker-compose.yml service definitions.
#
# ⚠️  CHANGE THESE FOR PRODUCTION — do not use default password!
#     Generate a strong password: openssl rand -base64 32
#
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=replace-with-strong-password
# POSTGRES_DB=shackles_symposium
# NEXTAUTH_URL=https://your-production-domain.com
# NEXTAUTH_SECRET=replace-with-nextauth-secret
#
# Connection routing (docker-compose handles this automatically):
#   App/Worker → PgBouncer (port 5432, pooled) → Postgres
#   Migrations → Postgres directly (port 5432, no pooler)
#
# PgBouncer is configured in docker-compose.yml with:
#   - Transaction pooling mode (compatible with Prisma)
#   - 80 server connections to Postgres (DEFAULT_POOL_SIZE)
#   - 1000 max client connections (MAX_CLIENT_CONN)
#   - Suitable for 500+ concurrent users

# -----------------------------------------------------------------------------
# Testing Environment Overrides (Playwright)
# -----------------------------------------------------------------------------

# Optional: Override database URL for Playwright tests (separate test DB)
# PLAYWRIGHT_DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_test?schema=public

# Optional: Override session secret for Playwright tests
# PLAYWRIGHT_SESSION_SECRET=test-session-secret

# Optional: Override SMTP for Playwright tests
# PLAYWRIGHT_SMTP_HOST=smtp.test.local
# PLAYWRIGHT_SMTP_PORT=1025
# PLAYWRIGHT_SMTP_USER=test@example.com
# PLAYWRIGHT_SMTP_PASS=test-password
